{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server={DATABASE_SERVER};port={DATABASE_PORT};database={DATABASE_NAME};user={DATABASE_USERADMIN};password={DATABASE_PASSWORD};"
  }
}
